{
  "$schema": "https://schemas.anthropic.com/skills/design-tokens/v1",
  "meta": {
    "source": "http://localhost:8899 — 小耳 Art Studio",
    "captured": "2026-04-17",
    "title": "小耳 Art Studio",
    "tagline": "Everyday uki uki. Sometimes doki doki.",
    "languages": ["ja", "en", "zh"],
    "license": "CC-BY-4.0 (methodology); original assets © 小耳"
  },

  "color": {
    "ink": {
      "primary": "#111111",
      "drawn-line": "#1a1a1a",
      "secondary": "#444444",
      "tertiary": "#666666",
      "muted": "#888888"
    },
    "surface": {
      "canvas": "#ffffff",
      "wash": "#f5f5f5"
    },
    "pastel-rotation": {
      "mint":   "#CCE8B0",
      "mint-2": "#DDECC8",
      "cream":  "#FFF8BE",
      "cream-2":"#FEFCE0",
      "cherry": "#FFE5E5",
      "cherry-2":"#FFB3B3",
      "sky":    "#C2EEF7",
      "peach":  "#C8A898",
      "olive":  "#D8D870",
      "teal":   "#8AADA8",
      "sage":   "#B8D8B0"
    },
    "accent": {
      "lime": "#c8ff00",
      "__rule__": "Use ≤3 times per page. Never pair with another saturated color."
    },
    "svg-palette": {
      "petal-pink":"#f0b0c0",
      "petal-pink-2":"#f5bec8",
      "petal-blue":"#a8d4e0",
      "petal-blue-2":"#b8d8c8",
      "petal-center":"#e879a0",
      "stamen-yellow":"#ffe066",
      "stem":"#4a9855",
      "stem-2":"#5aab60",
      "stem-3":"#88c890",
      "berry":"#d8d825",
      "berry-outline":"#5a6018",
      "divider-dot":"#5a8a38",
      "shadow-blue":"#98b8d8",
      "bloom-red":"#e06868",
      "bloom-red-2":"#e87878",
      "sage-deep":"#60b8a0",
      "sage-bright":"#98d870"
    }
  },

  "typography": {
    "families": {
      "serif":       "'DM Serif Display', Georgia, 'Songti SC', serif",
      "handwritten": "'Caveat', 'Dancing Script', cursive",
      "sans":        "system-ui, -apple-system, 'Helvetica Neue', 'PingFang SC', 'Hiragino Kaku Gothic ProN', sans-serif"
    },
    "roles": {
      "brand-mark":    { "family": "serif",       "size": "20px", "weight": 400, "italic": true  },
      "brand-sub":     { "family": "sans",        "size": "13px", "weight": 400, "color": "muted" },
      "hero-headline": { "family": "handwritten", "size": "56px", "weight": 400, "lineHeight": 1.3 },
      "section-label": { "family": "handwritten", "size": "32px", "weight": 400 },
      "work-title":    { "family": "serif",       "size": "20px", "weight": 400, "italic": true  },
      "work-subtitle": { "family": "sans",        "size": "13px", "weight": 400, "color": "muted" },
      "body":          { "family": "sans",        "size": "15px", "weight": 400, "lineHeight": 1.9, "color": "secondary" },
      "caption":       { "family": "sans",        "size": "12px", "weight": 400, "color": "muted", "letterSpacing": "0.08em", "transform": "uppercase" },
      "price":         { "family": "sans",        "size": "12px", "weight": 400, "color": "secondary" },
      "product-kanji": { "family": "sans",        "size": "16px", "weight": 400 }
    },
    "pairing-rule": "handwritten ↔ serif ↔ sans MUST each carry exactly one role category. Never mix (e.g. never use serif for body, never use cursive for pricing)."
  },

  "space": {
    "nav-height": "64px",
    "section-padding-y": "96px",
    "section-padding-x": "max(48px, 6vw)",
    "paragraph-gap": "28px",
    "column-gap": "64px",
    "hero-top-ratio": 0.45,
    "hero-decoration-bottom-inset": "0px"
  },

  "section-rhythm": [
    { "name": "hero",        "bg": "canvas",  "height": "100vh",  "decoration": "bottom-edge-florals" },
    { "name": "brand-intro", "bg": "canvas",  "layout": "2col-bilingual", "decoration": "scattered-corner-blobs" },
    { "name": "products",    "bg": "mint",    "layout": "4x2-circle-grid","label": "Products (cursive)" },
    { "name": "collections", "bg": "canvas",  "layout": "3col",           "label": "Collections Archives (cursive)" },
    { "name": "about",       "bg": "cream-2", "layout": "profile+links",  "label": "About (cursive)" },
    { "name": "news",        "bg": "canvas",  "layout": "date-list",      "label": "News (cursive)" },
    { "name": "contact",     "bg": "sky",     "layout": "2col-info",      "label": "Contact (cursive)" },
    { "name": "footer",      "bg": "canvas",  "layout": "centered-wordmark" }
  ],

  "dividers": {
    "between-sections": {
      "type": "dotted-line-svg",
      "dot-color": "#5a8a38",
      "dot-radius": 1.5,
      "dot-spacing-px": 16,
      "viewBox-pattern": "repeating circles across 100% width"
    },
    "under-section-label": {
      "type": "wavy-path-svg",
      "stroke": "#1a1a1a",
      "stroke-width": 1.2,
      "path-template": "M0 7 Q60 3 120 7 Q180 11 240 7 Q…"
    }
  },

  "svg-language": {
    "stroke-color": "#1a1a1a",
    "stroke-widths": [1.2, 1.5, 1.8, 2.2, 2.5],
    "stroke-linecap": "round",
    "preferred-commands": ["M", "Q", "C"],
    "avoid-commands": ["L for primary silhouette", "perfect arcs"],
    "rotation-style": "irregular radians, e.g. 0.12, -0.59, 0.36 — never 0/45/90",
    "overlap-opacity-range": [0.55, 0.93],
    "fill-policy": "pastel fill + visible stroke (both present)"
  },

  "motion": {
    "timing-function-default": "cubic-bezier(0.22, 1, 0.36, 1)",
    "timing-function-idle":    "ease-in-out",
    "named": {
      "heroTextIn": {
        "duration-ms": 800,
        "delay-ms": 200,
        "keyframes": [
          { "at": 0, "opacity": 0, "transformY": "24px" },
          { "at": 1, "opacity": 1, "transformY": "0px" }
        ],
        "iterations": 1
      },
      "about-float": {
        "duration-ms-range": [3600, 5000],
        "delay-stagger-ms": [0, 400, 800, 1300],
        "amplitude-px": 5,
        "iterations": "infinite"
      },
      "nd-float": {
        "duration-ms-range": [5200, 6400],
        "amplitude-px": 9,
        "preserve-rotation": true,
        "iterations": "infinite"
      },
      "nd-sway": {
        "duration-ms-range": [6800, 7000],
        "keyframes": 4,
        "rotation-delta-deg": 4,
        "scale-delta": 0.03,
        "iterations": "infinite"
      }
    },
    "rules": [
      "idle motion ≥3500ms",
      "amplitude ≤10px",
      "no scroll-triggered motion",
      "always stagger grouped elements"
    ]
  },

  "content-style": {
    "hero-headline-pattern": "Everyday <onomatopoeia>. Sometimes <onomatopoeia>.",
    "hero-headline-examples": [
      "Everyday uki uki. Sometimes doki doki.",
      "Everyday pitter-patter. Sometimes flutter-flutter."
    ],
    "product-name-style": "single meaningful ideogram (kanji/hanzi)",
    "product-name-examples": ["于", "知", "风", "果", "色", "常", "在", "舞"],
    "bilingual-column-layout": { "left": "ja (poetic lines)", "right": "en (matched breaks)" },
    "collection-title-style": "serif italic, 3–7 words, evocative phrase",
    "collection-title-examples": [
      "Daily Flowers",
      "Stones & Gemstones Found on Imaginary Islands",
      "The Garden of Reverie"
    ],
    "section-label-style": "handwritten cursive, single capitalized word (Products, About, News, Contact)"
  }
}
